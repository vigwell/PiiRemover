@page
@model IndexModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>PiiRemover — On-Premises PII Redaction Platform</title>
<meta name="description" content="Enterprise-grade PII redaction for healthcare. Pixel-level image redaction, 500k-term matching, smart dark-background OCR, Preserve Fields. 100% on-premises, air-gapped, HIPAA-ready."/>
<style>
/* ── Reset & base ─────────────────────────────────────────────────────── */
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:    #0a0f1e;
  --navy2:   #0e1628;
  --navy3:   #111e35;
  --blue:    #1a6ff0;
  --blue2:   #0d4fc4;
  --cyan:    #00c8ff;
  --green:   #00e5a0;
  --red:     #ff4560;
  --purple:  #8b5cf6;
  --orange:  #ff9500;
  --text:    #e8edf5;
  --text2:   #8b9bbf;
  --text3:   #5a6a8a;
  --border:  rgba(255,255,255,.08);
  --card:    rgba(255,255,255,.04);
  --glow:    0 0 40px rgba(26,111,240,.25);
  --font:    -apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;
}
html{scroll-behavior:smooth}
body{font-family:var(--font);background:var(--navy);color:var(--text);font-size:16px;line-height:1.6;overflow-x:hidden}
a{color:var(--cyan);text-decoration:none}
a:hover{text-decoration:underline}

/* ── Utility ──────────────────────────────────────────────────────────── */
.container{max-width:1160px;margin:0 auto;padding:0 24px}
.section{padding:96px 0}
.section-alt{background:var(--navy2)}
.tag{display:inline-block;background:rgba(26,111,240,.15);color:var(--cyan);border:1px solid rgba(0,200,255,.2);padding:4px 14px;border-radius:20px;font-size:12px;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:16px}
.tag-new{background:rgba(0,229,160,.12);color:var(--green);border-color:rgba(0,229,160,.3)}
.section-title{font-size:clamp(28px,4vw,42px);font-weight:800;line-height:1.2;margin-bottom:16px}
.section-sub{color:var(--text2);font-size:18px;max-width:640px;margin-bottom:48px}
.text-center{text-align:center}
.text-center .section-sub{margin-left:auto;margin-right:auto}
.gradient-text{background:linear-gradient(135deg,var(--cyan),var(--blue));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.gradient-text-green{background:linear-gradient(135deg,var(--green),var(--cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.btn{display:inline-flex;align-items:center;gap:8px;padding:14px 32px;border-radius:8px;font-size:15px;font-weight:700;cursor:pointer;transition:all .2s;border:none;text-decoration:none}
.btn-primary{background:linear-gradient(135deg,var(--blue),var(--blue2));color:#fff;box-shadow:0 4px 20px rgba(26,111,240,.4)}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 30px rgba(26,111,240,.5);text-decoration:none;color:#fff}
.btn-outline{background:transparent;color:var(--cyan);border:1.5px solid var(--cyan)}
.btn-outline:hover{background:rgba(0,200,255,.08);transform:translateY(-2px);text-decoration:none}
.btn-green{background:linear-gradient(135deg,#00b37a,#00e5a0);color:#0a0f1e}
.btn-green:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,229,160,.35);text-decoration:none;color:#0a0f1e}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:32px}
.grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
@@media(max-width:900px){.grid-2,.grid-3{grid-template-columns:1fr}.grid-4{grid-template-columns:1fr 1fr}}
@@media(max-width:560px){.grid-4{grid-template-columns:1fr}}

/* ── Nav ──────────────────────────────────────────────────────────────── */
.nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:0 24px;height:64px;display:flex;align-items:center;justify-content:space-between;background:rgba(10,15,30,.85);backdrop-filter:blur(12px);border-bottom:1px solid var(--border)}
.nav-brand{display:flex;align-items:center;gap:10px;font-size:18px;font-weight:800;color:#fff}
.nav-brand .shield{width:32px;height:32px;background:linear-gradient(135deg,var(--blue),var(--cyan));border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px}
.nav-links{display:flex;gap:28px;align-items:center}
.nav-links a{color:var(--text2);font-size:14px;font-weight:500;transition:color .15s}
.nav-links a:hover{color:#fff;text-decoration:none}
.nav-cta{background:var(--blue);color:#fff !important;padding:8px 20px;border-radius:6px;font-size:13px;font-weight:700}
.nav-cta:hover{background:var(--blue2);color:#fff;text-decoration:none}
@@media(max-width:768px){.nav-links{display:none}}

/* ── Hero ─────────────────────────────────────────────────────────────── */
.hero{min-height:100vh;display:flex;align-items:center;padding-top:64px;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 60% 40%,rgba(26,111,240,.12) 0%,transparent 70%)}
.hero-grid{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center}
@@media(max-width:900px){.hero-grid{grid-template-columns:1fr}}
.hero-badge{display:flex;align-items:center;gap:8px;background:rgba(0,229,160,.08);border:1px solid rgba(0,229,160,.2);color:var(--green);padding:6px 16px;border-radius:20px;font-size:12px;font-weight:700;letter-spacing:.8px;text-transform:uppercase;width:fit-content;margin-bottom:24px}
.hero-badge .dot{width:6px;height:6px;background:var(--green);border-radius:50%;animation:pulse 2s infinite}
@@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.hero h1{font-size:clamp(36px,5vw,58px);font-weight:900;line-height:1.1;margin-bottom:24px}
.hero-sub{font-size:18px;color:var(--text2);margin-bottom:40px;max-width:520px}
.hero-actions{display:flex;gap:16px;flex-wrap:wrap}
.hero-stats{display:flex;gap:32px;margin-top:48px;padding-top:32px;border-top:1px solid var(--border)}
.hero-stat .val{font-size:28px;font-weight:800;color:#fff}
.hero-stat .lbl{font-size:12px;color:var(--text3);text-transform:uppercase;letter-spacing:.8px}

/* Terminal */
.terminal{background:#070c19;border:1px solid var(--border);border-radius:12px;overflow:hidden;box-shadow:var(--glow)}
.terminal-bar{background:rgba(255,255,255,.05);padding:10px 16px;display:flex;align-items:center;gap:6px}
.dot-r{width:10px;height:10px;border-radius:50%;background:#ff5f56;display:inline-block}
.dot-y{width:10px;height:10px;border-radius:50%;background:#febc2e;display:inline-block}
.dot-g{width:10px;height:10px;border-radius:50%;background:#27c93f;display:inline-block}
.terminal-body{padding:20px 24px;font-family:'Courier New',monospace;font-size:13px;line-height:1.8}
.t-comment{color:var(--text3)}
.t-key{color:var(--cyan)}
.t-val{color:var(--green)}
.t-str{color:#ffb347}
.t-red{color:var(--red)}
.t-dim{color:var(--text3)}
.t-purple{color:#c4b5fd}

/* ── "What's New" banner ──────────────────────────────────────────────── */
.whats-new-banner{
  background:linear-gradient(135deg,rgba(0,229,160,.07) 0%,rgba(26,111,240,.1) 50%,rgba(139,92,246,.07) 100%);
  border:1px solid rgba(0,229,160,.2);border-radius:20px;
  padding:48px 56px;position:relative;overflow:hidden;
}
.whats-new-banner::before{
  content:'';position:absolute;top:-60px;right:-60px;
  width:240px;height:240px;border-radius:50%;
  background:radial-gradient(circle,rgba(0,229,160,.12),transparent 70%);
}
.new-feature-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;margin-top:36px}
@@media(max-width:768px){.new-feature-grid{grid-template-columns:1fr}}
.new-feature-item{
  display:flex;gap:14px;align-items:flex-start;
  background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);
  border-radius:12px;padding:18px 20px;transition:border-color .2s;
}
.new-feature-item:hover{border-color:rgba(0,229,160,.25)}
.new-feature-item .nf-icon{
  width:40px;height:40px;border-radius:10px;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;font-size:20px;
}
.new-feature-item h4{font-size:15px;font-weight:700;margin-bottom:4px}
.new-feature-item p{font-size:13px;color:var(--text2);line-height:1.5}
.nf-bg-green{background:rgba(0,229,160,.12)}
.nf-bg-blue{background:rgba(26,111,240,.15)}
.nf-bg-purple{background:rgba(139,92,246,.12)}
.nf-bg-orange{background:rgba(255,149,0,.12)}
.nf-bg-cyan{background:rgba(0,200,255,.12)}

/* ── Problem / Solution ───────────────────────────────────────────────── */
.problem-card{background:rgba(255,69,96,.06);border:1px solid rgba(255,69,96,.2);border-radius:12px;padding:24px}
.problem-card .icon{font-size:28px;margin-bottom:12px}
.problem-card h4{font-size:15px;font-weight:700;margin-bottom:8px;color:var(--red)}
.problem-card p{font-size:14px;color:var(--text2)}
.solution-card{background:rgba(0,229,160,.05);border:1px solid rgba(0,229,160,.15);border-radius:12px;padding:24px}
.solution-card .icon{font-size:28px;margin-bottom:12px}
.solution-card h4{font-size:15px;font-weight:700;margin-bottom:8px;color:var(--green)}
.solution-card p{font-size:14px;color:var(--text2)}

/* ── Feature cards ────────────────────────────────────────────────────── */
.feature-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:28px;transition:all .25s}
.feature-card:hover{border-color:rgba(0,200,255,.3);box-shadow:0 8px 32px rgba(26,111,240,.15);transform:translateY(-4px)}
.feature-card.highlight{border-color:rgba(0,229,160,.25);background:rgba(0,229,160,.03)}
.feature-card.highlight:hover{border-color:rgba(0,229,160,.5);box-shadow:0 8px 32px rgba(0,229,160,.12)}
.feature-icon{width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:22px;margin-bottom:16px}
.feature-card h3{font-size:17px;font-weight:700;margin-bottom:8px}
.feature-card p{font-size:14px;color:var(--text2);line-height:1.6}
.new-pill{display:inline-block;background:linear-gradient(135deg,rgba(0,229,160,.2),rgba(0,229,160,.1));color:var(--green);border:1px solid rgba(0,229,160,.3);font-size:10px;font-weight:800;padding:2px 8px;border-radius:10px;letter-spacing:.6px;text-transform:uppercase;margin-left:8px;vertical-align:middle}
.fi-blue{background:rgba(26,111,240,.15)}
.fi-cyan{background:rgba(0,200,255,.12)}
.fi-green{background:rgba(0,229,160,.12)}
.fi-purple{background:rgba(139,92,246,.12)}
.fi-orange{background:rgba(255,149,0,.12)}
.fi-red{background:rgba(255,69,96,.12)}

/* ── Image redaction demo ─────────────────────────────────────────────── */
.dicom-demo{
  background:#070c19;border:1px solid var(--border);border-radius:12px;overflow:hidden;
  box-shadow:0 0 40px rgba(0,229,160,.12);
}
.dicom-bar{
  background:rgba(255,255,255,.04);padding:8px 16px;
  display:flex;align-items:center;gap:8px;border-bottom:1px solid var(--border);
}
.dicom-split{display:grid;grid-template-columns:1fr 1fr}
.dicom-pane{padding:16px;position:relative}
.dicom-pane:first-child{border-right:1px solid var(--border)}
.dicom-label{font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;
             color:var(--text3);margin-bottom:10px}
.dicom-img{
  background:#000;border-radius:6px;padding:12px;
  font-family:'Courier New',monospace;font-size:11px;line-height:1.9;color:#ddd;
}
.dicom-redacted{background:#1a1a2e;border:2px solid rgba(0,229,160,.2);border-radius:6px;padding:12px;
  font-family:'Courier New',monospace;font-size:11px;line-height:1.9;color:#ddd;}
.blk{display:inline-block;background:#000;color:transparent;border-radius:2px;
     min-width:60px;height:14px;vertical-align:middle;margin:0 2px}
.blk-sm{min-width:40px}
.blk-lg{min-width:90px}

/* ── Flow ─────────────────────────────────────────────────────────────── */
.flow{display:flex;align-items:center;gap:0;flex-wrap:wrap;justify-content:center;margin-top:48px}
.flow-step{text-align:center;flex:1;min-width:140px;max-width:180px;padding:0 8px}
.flow-circle{width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg,var(--navy3),var(--navy2));border:2px solid var(--blue);display:flex;align-items:center;justify-content:center;font-size:28px;margin:0 auto 14px;box-shadow:0 0 20px rgba(26,111,240,.2)}
.flow-step h4{font-size:14px;font-weight:700;margin-bottom:4px}
.flow-step p{font-size:12px;color:var(--text3)}
.flow-arrow{font-size:20px;color:var(--text3);padding:0 4px;margin-bottom:28px}
@@media(max-width:768px){.flow-arrow{display:none}}

/* ── Code block ───────────────────────────────────────────────────────── */
.code-block{background:#070c19;border:1px solid var(--border);border-radius:10px;padding:20px 24px;font-family:'Courier New',monospace;font-size:13px;line-height:1.8;overflow-x:auto}
.code-block .cb{color:var(--text3)}
.code-block .ck{color:var(--cyan)}
.code-block .cv{color:var(--green)}
.code-block .cs{color:#ffb347}

/* ── Pricing ──────────────────────────────────────────────────────────── */
.pricing-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:36px;text-align:center;transition:all .25s}
.pricing-card.featured{border-color:var(--blue);box-shadow:0 0 40px rgba(26,111,240,.2)}
.pricing-card .plan{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text3);margin-bottom:8px}
.pricing-card .price{font-size:42px;font-weight:900;margin:12px 0;color:#fff}
.pricing-card .price span{font-size:16px;color:var(--text2);font-weight:400}
.pricing-card .desc{font-size:14px;color:var(--text2);margin-bottom:28px}
.pricing-card ul{list-style:none;text-align:left;margin-bottom:32px}
.pricing-card ul li{font-size:14px;color:var(--text2);padding:6px 0;display:flex;gap:10px}
.pricing-card ul li::before{content:'✓';color:var(--green);font-weight:700;flex-shrink:0}
.pricing-card ul li.new-li::before{content:'★';color:var(--cyan)}
.badge-featured{background:linear-gradient(135deg,var(--blue),var(--cyan));color:#fff;font-size:11px;font-weight:700;padding:3px 12px;border-radius:20px;display:inline-block;margin-bottom:16px}

/* ── Stats bar ────────────────────────────────────────────────────────── */
.stats-bar{background:linear-gradient(135deg,var(--navy3),#0d1a35);border:1px solid var(--border);border-radius:16px;padding:40px;display:grid;grid-template-columns:repeat(4,1fr);gap:24px;text-align:center}
@@media(max-width:768px){.stats-bar{grid-template-columns:1fr 1fr}}
.stat-item .num{font-size:36px;font-weight:900;background:linear-gradient(135deg,var(--cyan),var(--blue));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.stat-item .label{font-size:13px;color:var(--text3);margin-top:4px}

/* ── Compliance badges ────────────────────────────────────────────────── */
.compliance-grid{display:flex;flex-wrap:wrap;gap:16px;justify-content:center;margin-top:40px}
.compliance-badge{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:16px 28px;font-size:13px;font-weight:700;color:var(--text2);display:flex;align-items:center;gap:10px}
.compliance-badge .icon{font-size:20px}

/* ── Quote ────────────────────────────────────────────────────────────── */
.quote-card{background:var(--card);border:1px solid var(--border);border-left:3px solid var(--blue);border-radius:0 12px 12px 0;padding:28px 32px;margin-bottom:24px}
.quote-card p{font-size:16px;color:var(--text);font-style:italic;margin-bottom:16px}
.quote-card .author{font-size:13px;color:var(--text3);font-weight:600}

/* ── Contact ──────────────────────────────────────────────────────────── */
.contact-card{background:linear-gradient(135deg,var(--navy3),#0d1a35);border:1px solid var(--border);border-radius:20px;padding:56px;text-align:center}
.contact-card h2{font-size:36px;font-weight:800;margin-bottom:16px}
.contact-card p{font-size:18px;color:var(--text2);margin-bottom:36px}
.contact-email{display:inline-flex;align-items:center;gap:12px;background:rgba(26,111,240,.12);border:1px solid rgba(26,111,240,.3);color:var(--cyan);padding:16px 32px;border-radius:10px;font-size:18px;font-weight:600;margin-bottom:32px;transition:all .2s}
.contact-email:hover{background:rgba(26,111,240,.2);text-decoration:none;transform:translateY(-2px)}

/* ── Footer ───────────────────────────────────────────────────────────── */
footer{background:var(--navy);border-top:1px solid var(--border);padding:48px 0 32px}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:40px;margin-bottom:40px}
@@media(max-width:768px){.footer-grid{grid-template-columns:1fr 1fr}}
.footer-brand p{font-size:14px;color:var(--text3);margin-top:12px;max-width:280px;line-height:1.6}
.footer-col h5{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text3);margin-bottom:16px}
.footer-col ul{list-style:none}
.footer-col ul li{margin-bottom:10px}
.footer-col ul li a{color:var(--text2);font-size:14px;transition:color .15s}
.footer-col ul li a:hover{color:#fff;text-decoration:none}
.footer-bottom{border-top:1px solid var(--border);padding-top:24px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px}
</style>
</head>
<body>

<!-- ── Navigation ───────────────────────────────────────────────────── -->
<nav class="nav">
  <div class="nav-brand">
    <div class="shield">&#x1F512;</div>
    PiiRemover
  </div>
  <div class="nav-links">
    <a href="#whats-new">What's New</a>
    <a href="#features">Features</a>
    <a href="#how-it-works">How It Works</a>
    <a href="#api">API</a>
    <a href="#security">Security</a>
    <a href="#pricing">Licensing</a>
    <a href="#contact" class="nav-cta">Contact Sales</a>
  </div>
</nav>

<!-- ── Hero ─────────────────────────────────────────────────────────── -->
<section class="hero">
  <div class="container">
    <div class="hero-grid">
      <div>
        <div class="hero-badge">
          <span class="dot"></span>
          100% On-Premises &mdash; Your Data Never Leaves
        </div>
        <h1>
          Enterprise PII Redaction<br/>
          <span class="gradient-text">Built for Healthcare</span>
        </h1>
        <p class="hero-sub">
          Automatically detect and redact patient identifiers from scanned documents,
          PDFs, DICOM images, and clinical screenshots &mdash; in Hebrew and English &mdash;
          without sending a single byte to the cloud.
        </p>
        <div class="hero-actions">
          <a href="#contact" class="btn btn-primary">Request a Demo</a>
          <a href="#whats-new" class="btn btn-green">&#x2728; What's New</a>
          <a href="#how-it-works" class="btn btn-outline">See How It Works</a>
        </div>
        <div class="hero-stats">
          <div class="hero-stat"><div class="val">100%</div><div class="lbl">On-Premises</div></div>
          <div class="hero-stat"><div class="val">500k+</div><div class="lbl">Terms/Field</div></div>
          <div class="hero-stat"><div class="val">&#x05D4;&#x05E2;</div><div class="lbl">Hebrew + English</div></div>
          <div class="hero-stat"><div class="val">🖼+📄</div><div class="lbl">Image + Text</div></div>
        </div>
      </div>
      <div>
        <!-- Tab between text redaction and image redaction demo -->
        <div style="display:flex;gap:0;margin-bottom:-1px;position:relative;z-index:1">
          <button id="tab-text" onclick="switchDemo('text')"
            style="background:#070c19;border:1px solid rgba(26,111,240,.4);border-bottom:none;
                   color:var(--cyan);padding:7px 18px;font-size:12px;font-weight:700;
                   border-radius:8px 8px 0 0;cursor:pointer;letter-spacing:.5px">
            📄 TEXT REDACT
          </button>
          <button id="tab-image" onclick="switchDemo('image')"
            style="background:var(--navy3);border:1px solid var(--border);border-bottom:none;
                   color:var(--text3);padding:7px 18px;font-size:12px;font-weight:700;
                   border-radius:8px 8px 0 0;cursor:pointer;letter-spacing:.5px;margin-left:4px">
            🖼 IMAGE REDACT
          </button>
        </div>

        <!-- Text redaction terminal -->
        <div id="demo-text" class="terminal">
          <div class="terminal-bar">
            <span class="dot-r"></span><span class="dot-y"></span><span class="dot-g"></span>
            <span style="font-size:12px;color:var(--text3);margin-left:8px">POST /api/v1/redact/redact</span>
          </div>
          <div class="terminal-body">
<span class="t-comment">// Input document text</span><br/>
<span class="t-key">Patient:</span> <span class="t-str">&#x05DB;&#x05D4;&#x05DF; &#x05E9;&#x05D0;&#x05D5;&#x05DC;</span><br/>
<span class="t-key">ID:</span>      <span class="t-val">205447709</span><br/>
<span class="t-key">DOB:</span>     <span class="t-val">30/11/1994</span><br/>
<span class="t-key">Phone:</span>   <span class="t-val">058-3245670</span><br/>
