<script>
// ── Demo tab switcher ────────────────────────────────────────────────
function switchDemo(tab) {
  const textDemo  = document.getElementById('demo-text');
  const imageDemo = document.getElementById('demo-image');
  const tabText   = document.getElementById('tab-text');
  const tabImage  = document.getElementById('tab-image');
  if (tab === 'text') {
    textDemo.style.display  = '';
    imageDemo.style.display = 'none';
    tabText.style.background  = '#070c19';
    tabText.style.color       = 'var(--cyan)';
    tabText.style.borderColor = 'rgba(26,111,240,.4)';
    tabImage.style.background = 'var(--navy3)';
    tabImage.style.color      = 'var(--text3)';
    tabImage.style.borderColor = 'var(--border)';
  } else {
    textDemo.style.display  = 'none';
    imageDemo.style.display = '';
    tabImage.style.background  = '#070c19';
    tabImage.style.color       = 'var(--green)';
    tabImage.style.borderColor = 'rgba(0,229,160,.4)';
    tabText.style.background   = 'var(--navy3)';
    tabText.style.color        = 'var(--text3)';
    tabText.style.borderColor  = 'var(--border)';
  }
}

// ── Active nav highlight on scroll ──────────────────────────────────
const sections = document.querySelectorAll('section[id]');
const navLinks = document.querySelectorAll('.nav-links a[href^="#"]');
window.addEventListener('scroll', () => {
  let cur = '';
  sections.forEach(s => { if (window.scrollY >= s.offsetTop - 80) cur = s.id; });
  navLinks.forEach(a => {
    a.style.color = a.getAttribute('href') === '#' + cur ? '#fff' : '';
  });
});
</script>

