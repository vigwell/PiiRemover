{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    },
    "EventLog": {
      "SourceName": "PiiRemover",
      "LogName": "PiiRemover",
      "Mode": "Production"
    },
    "RetentionMonths": 1
  },
  "AllowedHosts": "*",
  "PathBase": "",
  "License": {
    "FilePath": "license.lic"
  },
  "Database": {
    "Path": "piiremovals.db"
  },
  "Ocr": {
    "EngineOrder": [ "WindowsOcr", "Tesseract" ],
    "TessdataPath": "tessdata",
    "TesseractLanguages": "heb+eng",
    "MaxConcurrency": 0
  }
}
