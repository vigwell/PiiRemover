@page "/admin/login"
@model PiiRemover.Api.Pages.Admin.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<script>(function(){var t=localStorage.getItem('pii-theme')||'dark';document.documentElement.setAttribute('data-theme',t)})();</script>
<title>PiiRemover — Login</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#f0f2f5;--surface:#fff;--text:#222;--text2:#444;--sub:#888;--border:#d9d9d9;--title:#001529}
[data-theme="dark"]{--bg:#0d1117;--surface:#161b22;--text:#e6edf3;--text2:#adbac7;--sub:#636e7b;--border:#444c56;--title:#e6edf3}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;
     background:var(--bg);color:var(--text);display:flex;align-items:center;justify-content:center;min-height:100vh;transition:background .2s}
.box{background:var(--surface);border-radius:8px;box-shadow:0 2px 12px rgba(0,0,0,.3);
     padding:40px;width:360px;border:1px solid var(--border)}
.logo{text-align:center;font-size:22px;font-weight:700;color:var(--title);margin-bottom:8px}
.sub{text-align:center;color:var(--sub);font-size:13px;margin-bottom:28px}
label{display:block;font-size:13px;font-weight:500;color:var(--text2);margin-bottom:4px}
input{width:100%;background:var(--surface);color:var(--text);border:1px solid var(--border);
      border-radius:4px;padding:8px 12px;font-size:14px;outline:none;transition:border-color .2s;margin-bottom:14px}
input:focus{border-color:#1677ff;box-shadow:0 0 0 2px rgba(22,119,255,.2)}
button{width:100%;background:#1677ff;color:#fff;border:none;border-radius:4px;padding:10px;
       font-size:15px;font-weight:600;cursor:pointer;transition:background .2s;margin-top:4px}
button:hover{background:#0958d9}
.err{background:#2a1215;border:1px solid #58181c;color:#e84749;border-radius:4px;
     padding:8px 12px;font-size:13px;margin-bottom:14px}
[data-theme="light"] .err{background:#fff2f0;border-color:#ffccc7;color:#cf1322}
</style>
</head>
<body>
<div class="box">
  <div class="logo">🔒 PiiRemover</div>
  <div class="sub">Administration Console</div>

  @if (!string.IsNullOrEmpty(Model.Error))
  {
    <div class="err">@Model.Error</div>
  }

  <form method="post">
    <label>Username</label>
    <input type="text" asp-for="Username" autocomplete="username" placeholder="admin" />
    <label>Password</label>
    <input type="password" asp-for="Password" autocomplete="current-password" placeholder="••••••" />
    <input type="hidden" asp-for="ReturnUrl" />
    <button type="submit">Sign In</button>
  </form>
</div>
</body>
</html>
