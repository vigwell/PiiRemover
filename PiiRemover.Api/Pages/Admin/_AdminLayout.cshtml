<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>@ViewData["Title"] — PiiRemover Admin</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Arial,sans-serif;background:#f0f2f5;color:#222;font-size:14px}
a{color:#1677ff;text-decoration:none}a:hover{text-decoration:underline}
/* nav */
.nav{background:#001529;padding:0 24px;display:flex;align-items:center;height:48px;gap:24px}
.nav .brand{color:#fff;font-size:16px;font-weight:600;letter-spacing:.5px}
.nav a{color:#ffffffa0;font-size:13px;padding:4px 0}
.nav a:hover,.nav a.active{color:#fff;text-decoration:none}
.nav .spacer{flex:1}
.nav .logout{background:#ff4d4f;color:#fff;border:none;cursor:pointer;padding:4px 14px;border-radius:4px;font-size:13px}
.nav .logout:hover{background:#d9363e}
/* layout */
.page{max-width:1200px;margin:24px auto;padding:0 16px}
.page-title{font-size:20px;font-weight:600;margin-bottom:20px;color:#001529}
/* card */
.card{background:#fff;border-radius:8px;box-shadow:0 1px 4px #0001;padding:20px;margin-bottom:20px}
.card h3{font-size:15px;font-weight:600;margin-bottom:14px;padding-bottom:10px;border-bottom:1px solid #f0f0f0}
/* table */
table{width:100%;border-collapse:collapse}
th{background:#fafafa;text-align:left;padding:8px 12px;font-weight:600;font-size:13px;border-bottom:2px solid #f0f0f0}
td{padding:8px 12px;border-bottom:1px solid #f5f5f5;vertical-align:middle}
tr:last-child td{border-bottom:none}
tr:hover td{background:#fafafa}
/* form controls */
input[type=text],input[type=password],input[type=number],select,textarea{
  border:1px solid #d9d9d9;border-radius:4px;padding:6px 10px;font-size:13px;
  outline:none;transition:border-color .2s;width:100%}
input[type=text]:focus,input[type=password]:focus,input[type=number]:focus,
select:focus,textarea:focus{border-color:#1677ff;box-shadow:0 0 0 2px #1677ff20}
.form-row{display:flex;gap:8px;align-items:center;margin-bottom:12px}
.form-row label{white-space:nowrap;min-width:140px;font-weight:500;color:#555}
.form-row .ctrl{flex:1}
/* buttons */
.btn{display:inline-flex;align-items:center;padding:5px 14px;border-radius:4px;font-size:13px;
     cursor:pointer;border:1px solid transparent;transition:all .2s;white-space:nowrap}
.btn-primary{background:#1677ff;color:#fff;border-color:#1677ff}
.btn-primary:hover{background:#0958d9}
.btn-default{background:#fff;color:#555;border-color:#d9d9d9}
.btn-default:hover{border-color:#1677ff;color:#1677ff}
.btn-danger{background:#fff;color:#ff4d4f;border-color:#ff4d4f}
.btn-danger:hover{background:#ff4d4f;color:#fff}
.btn-sm{padding:3px 10px;font-size:12px}
.btn-link{background:none;border:none;color:#1677ff;cursor:pointer;padding:0;font-size:13px}
.btn-link:hover{text-decoration:underline}
/* alerts */
.alert{padding:10px 14px;border-radius:4px;margin-bottom:16px;font-size:13px}
.alert-success{background:#f6ffed;border:1px solid #b7eb8f;color:#389e0d}
.alert-warning{background:#fffbe6;border:1px solid #ffd666;color:#d46b08}
.alert-danger{background:#fff2f0;border:1px solid #ffccc7;color:#cf1322}
.alert-info{background:#e6f4ff;border:1px solid #91caff;color:#0958d9}
/* badges */
.badge{display:inline-block;padding:2px 8px;border-radius:10px;font-size:11px;font-weight:600}
.badge-green{background:#f6ffed;color:#389e0d;border:1px solid #b7eb8f}
.badge-red{background:#fff2f0;color:#cf1322;border:1px solid #ffccc7}
.badge-blue{background:#e6f4ff;color:#0958d9;border:1px solid #91caff}
/* grid */
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:20px}
@@media(max-width:768px){.grid-2,.grid-3{grid-template-columns:1fr}}
/* stat card */
.stat{text-align:center;padding:16px}
.stat .val{font-size:28px;font-weight:700;color:#1677ff}
.stat .lbl{font-size:12px;color:#888;margin-top:4px}
/* mono */
.mono{font-family:'Courier New',monospace;font-size:12px;background:#f5f5f5;padding:2px 6px;border-radius:3px}
</style>
</head>
<body>

<nav class="nav">
  <span class="brand">🔒 PiiRemover</span>
  <a href="/admin" class="@(ViewData["Nav"]?.ToString()=="home"?"active":"")">Dashboard</a>
  <a href="/admin/clients" class="@(ViewData["Nav"]?.ToString()=="clients"?"active":"")">Clients</a>
  <a href="/admin/fields" class="@(ViewData["Nav"]?.ToString()=="fields"?"active":"")">PII Fields</a>
  <a href="/admin/logs" class="@(ViewData["Nav"]?.ToString()=="logs"?"active":"")">Logs</a>
  <a href="/admin/settings" class="@(ViewData["Nav"]?.ToString()=="settings"?"active":"")">Settings</a>
  <span class="spacer"></span>
  <form method="post" asp-page-handler="Logout" style="margin:0">
    <button type="submit" class="logout">Logout</button>
  </form>
</nav>

<div class="page">
  @RenderBody()
</div>

</body>
</html>
