      <span id="textCharCount" style="font-size:11px;color:var(--text3);white-space:nowrap">0 chars</span>
    </div>
    <textarea class="text-input-area" id="textInput"
              placeholder="Type or paste text here… (English or Hebrew)"
              oninput="onTextInput()" dir="ltr"></textarea>
  </div>

  <!-- ─ Shared run area ─ -->
  <div class="run-area">
    <!-- File modes -->
    <div id="fileModeRow" class="mode-row">
      <label><input type="radio" name="fileMode" value="ocr-redact" checked><span>OCR + Redact</span></label>
      <label><input type="radio" name="fileMode" value="ocr-only"><span>OCR only</span></label>
