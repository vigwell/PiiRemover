  <!-- ─ TEXT tab ─ -->
  <div class="tab-panel" data-tab="text">
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:6px">
      <div class="text-toolbar" style="flex:1;margin-bottom:0">
        <button class="tb-btn" id="textDirBtn" onclick="textToggleDir()" title="Toggle text direction">← RTL</button>
        <span class="tb-sep"></span>
        <button class="tb-btn" onclick="textChangeFontSize(-1)" title="Smaller text">A−</button>
        <span class="tb-font-size" id="textFszLabel">13px</span>
        <button class="tb-btn" onclick="textChangeFontSize(+1)" title="Larger text">A+</button>
        <span class="tb-sep"></span>
        <button class="tb-btn" id="textClearBtn" onclick="clearTextInput()"
                style="display:none;color:#ff4d4f;border-color:rgba(255,77,79,.4)">✕ Clear</button>
