// ═══════════════════════════════════════════════════════════════════
// PANE CONTENT (OCR + REDACT HTML with PII + search highlights)
// ═══════════════════════════════════════════════════════════════════
function refreshPanes(id) {
  const s = cardStates.get(id);
  if (!s) return;
  const ocrPane = document.getElementById(id + '-ocrPane');
  const rdPane  = document.getElementById(id + '-rdPane');  // null in single-pane modes
  if (!ocrPane) return;

  if (s.textRedactOnly) {
    // Text / redact-only: single pane shows redacted output
    const rdHtml = buildRedactHtml(s.ocrText, s.piiMatches);
    ocrPane.innerHTML = s.searchTerm ? applySearchHighlights(rdHtml, s.searchTerm) : rdHtml;
  } else {
    // Normal: ocrPane = original highlighted, rdPane = redacted
    const ocrHtml = buildOcrHtml(s.ocrText, s.piiMatches);
    ocrPane.innerHTML = s.searchTerm ? applySearchHighlights(ocrHtml, s.searchTerm) : ocrHtml;
    if (rdPane) {
      const rdHtml = buildRedactHtml(s.ocrText, s.piiMatches);
      rdPane.innerHTML = s.searchTerm ? applySearchHighlights(rdHtml, s.searchTerm) : rdHtml;
    }
  }

  // Update hit count
  if (s.searchTerm) {
    s.hitCount = ocrPane.querySelectorAll('mark.search-hit').length;
    updateSearchBadge(id);
    if (s.hitCount > 0) scrollToHit(id, s.hitIdx);
  } else {
    s.hitCount = 0;
    updateSearchBadge(id);
  }
}

/** OCR pane: original text with PII positions highlighted in amber */
function buildOcrHtml(text, matches) {
  if (!text) return '<span style="color:var(--text3);font-style:italic">No text extracted.</span>';
  if (!matches || !matches.length) return escHtml(text);
  const sorted = [...matches].sort((a, b) => a.startIndex - b.startIndex);
  let html = '', pos = 0;
  for (const m of sorted) {
    const s = Math.min(m.startIndex, text.length);
    const e = Math.min(s + m.length, text.length);
    if (s > pos) html += escHtml(text.slice(pos, s));
    html += `<mark class="pii-orig" title="${ea(m.fieldName)}: ${ea(text.slice(s,e))}">${escHtml(text.slice(s,e))}</mark>`;
    pos = e;
  }
  if (pos < text.length) html += escHtml(text.slice(pos));
  return html;
}

/** Redact pane: rebuild from original positions but show replacement strings in green */
function buildRedactHtml(text, matches) {
  if (!text) return '<span style="color:var(--text3);font-style:italic">No text extracted.</span>';
  if (!matches || !matches.length) return escHtml(text);
  const sorted = [...matches].sort((a, b) => a.startIndex - b.startIndex);
  let html = '', pos = 0;
  for (const m of sorted) {
    const s = Math.min(m.startIndex, text.length);
    const e = Math.min(s + m.length, text.length);
    if (s > pos) html += escHtml(text.slice(pos, s));
    html += `<mark class="pii-repl" title="${ea(m.fieldName)}: &quot;${ea(m.matchedText)}&quot; → &quot;${ea(m.replacement)}&quot;">${escHtml(m.replacement)}</mark>`;
    pos = e;
  }
  if (pos < text.length) html += escHtml(text.slice(pos));
  return html;
}

/** Apply search highlights on top of existing HTML by walking text nodes */
function applySearchHighlights(html, term) {
  if (!term) return html;
  const tmp = document.createElement('div');
  tmp.innerHTML = html;
  const lower = term.toLowerCase();

  const walker = document.createTreeWalker(tmp, NodeFilter.SHOW_TEXT);
  const nodes  = [];
  let n;
  while ((n = walker.nextNode())) nodes.push(n);

  for (const node of nodes) {
    const txt   = node.textContent || '';
    const lower2 = txt.toLowerCase();
    if (lower2.indexOf(lower) === -1) continue;

    const frag = document.createDocumentFragment();
    let pos2   = 0;
    let idx;
    while ((idx = lower2.indexOf(lower, pos2)) !== -1) {
      if (idx > pos2) frag.appendChild(document.createTextNode(txt.slice(pos2, idx)));
      const mark = document.createElement('mark');
      mark.className = 'search-hit';
      mark.textContent = txt.slice(idx, idx + lower.length);
      frag.appendChild(mark);
      pos2 = idx + lower.length;
    }
    if (pos2 < txt.length) frag.appendChild(document.createTextNode(txt.slice(pos2)));
    node.parentNode.replaceChild(frag, node);
  }
  return tmp.innerHTML;
}

// ═══════════════════════════════════════════════════════════════════
// PER-CARD CONTROLS
// ═══════════════════════════════════════════════════════════════════
function toggleDir(id) {
  const s = cardStates.get(id); if (!s) return;
  s.dir = s.dir === 'rtl' ? 'ltr' : 'rtl';
  const btn = document.getElementById(id + '-dirBtn');
  if (btn) btn.textContent = s.dir === 'rtl' ? '→ LTR' : '← RTL';
  applyPaneAttrs(id);
}

function changeFontSize(id, delta) {
  const s = cardStates.get(id); if (!s) return;
  s.fontSize = Math.max(9, Math.min(20, s.fontSize + delta));
  const lbl = document.getElementById(id + '-fsz');
  if (lbl) lbl.textContent = s.fontSize + 'px';
  applyPaneAttrs(id);
}

function applyPaneAttrs(id) {
  const s = cardStates.get(id); if (!s) return;
  for (const sfx of ['-ocrPane', '-rdPane']) {
    const el = document.getElementById(id + sfx);
    if (el) { el.style.fontSize = s.fontSize + 'px'; el.dir = s.dir; }
  }
  // also update direction button text
  const dirBtn = document.getElementById(id + '-dirBtn');
  if (dirBtn) dirBtn.textContent = s.dir === 'rtl' ? '→ LTR' : '← RTL';
}

// Search
function onSearchInput(id) {
  const inp = document.getElementById(id + '-srch');
  if (!inp) return;
  const s = cardStates.get(id); if (!s) return;
  s.searchTerm = inp.value.trim();
  s.hitIdx     = 0;
  refreshPanes(id);
}

function onSearchKey(e, id) {
  if (e.key === 'Enter') navigateHit(id, e.shiftKey ? -1 : +1);
  if (e.key === 'Escape') clearSearch(id);
}

function clearSearch(id) {
  const inp = document.getElementById(id + '-srch');
  if (inp) inp.value = '';
  const s = cardStates.get(id); if (!s) return;
  s.searchTerm = ''; s.hitIdx = 0; s.hitCount = 0;
  refreshPanes(id);
  updateSearchBadge(id);
}

function navigateHit(id, dir) {
  const s = cardStates.get(id); if (!s || !s.hitCount) return;
  s.hitIdx = ((s.hitIdx + dir) % s.hitCount + s.hitCount) % s.hitCount;
  updateSearchBadge(id);
  scrollToHit(id, s.hitIdx);
}

function updateSearchBadge(id) {
  const s   = cardStates.get(id);
  const el  = document.getElementById(id + '-sbadge');
  if (!el || !s) return;
  el.textContent = s.hitCount > 0
    ? `${s.hitIdx + 1}/${s.hitCount}`
    : (s.searchTerm ? '0' : '');
}

function scrollToHit(id, idx) {
  const ocrPane = document.getElementById(id + '-ocrPane');
  const rdPane  = document.getElementById(id + '-rdPane');
  if (!ocrPane || !rdPane) return;

  const ocrHits = ocrPane.querySelectorAll('mark.search-hit');
  const rdHits  = rdPane.querySelectorAll('mark.search-hit');

  // De-activate all, activate current
  ocrHits.forEach((m, i) => m.classList.toggle('active', i === idx));
  rdHits.forEach( (m, i) => m.classList.toggle('active', i === idx));

  const hit = ocrHits[idx];
  if (hit) {
    const offset = hit.offsetTop;
    ocrPane.scrollTop = Math.max(0, offset - ocrPane.clientHeight * 0.35);
    // Sync redact pane proportionally
    const ratio = ocrPane.scrollTop / Math.max(1, ocrPane.scrollHeight - ocrPane.clientHeight);
    rdPane.scrollTop = ratio * Math.max(0, rdPane.scrollHeight - rdPane.clientHeight);
  }
}

// ═══════════════════════════════════════════════════════════════════
// SCROLL SYNC — bidirectional proportional sync between OCR / Redact
// ═══════════════════════════════════════════════════════════════════
function attachScrollSync(id) {
  const ocrPane = document.getElementById(id + '-ocrPane');
  const rdPane  = document.getElementById(id + '-rdPane');
  if (!ocrPane || !rdPane) return;  // ocr-only mode has no rdPane — skip sync

  let syncing = false;

  ocrPane.addEventListener('scroll', () => {
    if (syncing) return;
    syncing = true;
    const max   = ocrPane.scrollHeight - ocrPane.clientHeight;
    const ratio = max > 0 ? ocrPane.scrollTop / max : 0;
    rdPane.scrollTop = ratio * Math.max(0, rdPane.scrollHeight - rdPane.clientHeight);
    requestAnimationFrame(() => { syncing = false; });
  });

  rdPane.addEventListener('scroll', () => {
    if (syncing) return;
    syncing = true;
    const max   = rdPane.scrollHeight - rdPane.clientHeight;
    const ratio = max > 0 ? rdPane.scrollTop / max : 0;
    ocrPane.scrollTop = ratio * Math.max(0, ocrPane.scrollHeight - ocrPane.clientHeight);
    requestAnimationFrame(() => { syncing = false; });
  });
}

// ═══════════════════════════════════════════════════════════════════
// CONTEXT MENU (right-click on redact pane)
// ═══════════════════════════════════════════════════════════════════
const ctxMenu = document.getElementById('ctxMenu');
let ctxCardId = '';

document.getElementById('results').addEventListener('contextmenu', e => {
  const paneBody = e.target.closest('.pane-body');   // both OCR and Redact panes
  if (!paneBody) return;
  const sel = window.getSelection();
  const txt = sel ? sel.toString().trim() : '';
  if (!txt || txt.length > 300) return;
  e.preventDefault();
  ctxText   = txt;
  const card = paneBody.closest('.result-card');
  ctxCardId  = card ? card.id : '';
  ctxSource  = card ? (card.querySelector('.fname')?.textContent || '') : '';
  // label which pane the selection came from
  const isOcr = paneBody.closest('.pane-ocr') !== null;
  ctxSource  += isOcr ? ' (OCR)' : ' (Redacted)';
  ctxMenu.style.display = 'block';
  ctxMenu.style.left    = Math.min(e.clientX, window.innerWidth  - 210) + 'px';
  ctxMenu.style.top     = Math.min(e.clientY, window.innerHeight - 60)  + 'px';
});

document.addEventListener('click',       hideCtx);
document.addEventListener('contextmenu', e => { if (!e.target.closest('.pane-body')) hideCtx(); });
function hideCtx() { ctxMenu.style.display = 'none'; }

function ctxAddRedact() {
  hideCtx();
  if (!ctxText) return;
  openAddPii(ctxText, 'redact');
}

function ctxAddPreserve() {
  hideCtx();
  if (!ctxText) return;
  openAddPii(ctxText, 'preserve');
}

// ═══════════════════════════════════════════════════════════════════
// ADD VALUE MODAL  (Redact / Preserve)
// ═══════════════════════════════════════════════════════════════════
let addPiiMode = 'redact';   // 'redact' | 'preserve'

async function openAddPii(text, mode) {
  addPiiMode        = mode || 'redact';
  addPiiCurrentText = text;

  const isPreserve  = addPiiMode === 'preserve';
  document.getElementById('addPiiTitle').textContent =
    isPreserve ? '🛡 Add Value to Preserve' : '🔒 Add Value to Redact';
  document.getElementById('addPiiText').textContent = text;
  document.getElementById('addPiiStatus').textContent = '';

  // Show / hide Replace-with row (not needed for preserve)
  document.getElementById('addReplaceRow').style.display = isPreserve ? 'none' : '';

  // Reset to "existing" mode
  document.querySelector('input[name="addMode"][value="existing"]').checked = true;
  addModeChange();

  document.getElementById('addPiiModal').style.display = 'flex';

  if (!cachedFields) await reloadFields();
  else populateFieldSelect();
}

function closeAddPii() { document.getElementById('addPiiModal').style.display = 'none'; }

function addModeChange() {
  const mode = document.querySelector('input[name="addMode"]:checked')?.value || 'existing';
  document.getElementById('addExistingSection').style.display = mode === 'existing' ? '' : 'none';
  document.getElementById('addNewSection').style.display      = mode === 'new'      ? '' : 'none';

  const accent = '#1677ff';
  document.getElementById('addModeExistingLbl').style.borderColor = mode === 'existing' ? accent : 'var(--border2)';
  document.getElementById('addModeNewLbl').style.borderColor      = mode === 'new'      ? accent : 'var(--border2)';
}

async function reloadFields() {
  try {
    const r = await fetch('/admin/tester?handler=Fields');
    cachedFields = await r.json();
    populateFieldSelect();
  } catch (e) {
    setAddPiiStatus('Could not load fields: ' + e.message, 'error');
  }
}

function populateFieldSelect() {
  const isPreserve = addPiiMode === 'preserve';
  const filtered   = (cachedFields || []).filter(f => !!f.isPreserve === isPreserve);
  const sel        = document.getElementById('addFieldSelect');
  sel.innerHTML = '<option value="">— select a field —</option>'
    + filtered.map(f => {
        const label = isPreserve
          ? h(f.fieldName)
          : `${h(f.fieldName)} → ${h(f.replaceWith)}`;
        return `<option value="${f.id}">${label}</option>`;
      }).join('');
}

async function submitAddToExisting() {
  const fieldId = document.getElementById('addFieldSelect').value;
  if (!fieldId) { setAddPiiStatus('Please select a field.', 'error'); return; }

  setAddPiiStatus('Saving…', 'info');
  const r = await apiPost('/admin/tester?handler=AddPattern',
    { fieldId: +fieldId, patternType: 'WholeWord', pattern: addPiiCurrentText });
  if (r.ok) {
    setAddPiiStatus('✓ Added as Whole Word pattern.', 'ok');
    cachedFields = null;
  } else {
    setAddPiiStatus('Error: ' + (r.error || 'unknown'), 'error');
  }
}

async function submitAddNewField() {
  const name       = document.getElementById('addNewName').value.trim();
  const replace    = document.getElementById('addNewReplace').value.trim() || '████';
  const isPreserve = addPiiMode === 'preserve';

  if (!name) { setAddPiiStatus('Field name is required.', 'error'); return; }

  setAddPiiStatus('Creating field…', 'info');
  const r = await apiPost('/admin/tester?handler=CreateField', {
    fieldName:   name,
    replaceWith: isPreserve ? '—' : replace,
    patternType: 'WholeWord',
    pattern:     addPiiCurrentText,
    isPreserve
  });
  if (r.ok) {
    setAddPiiStatus(`✓ Field "${h(name)}" created.`, 'ok');
    cachedFields = null;
  } else {
    setAddPiiStatus('Error: ' + (r.error || 'unknown'), 'error');
  }
}

function setAddPiiStatus(msg, type) {
  const el  = document.getElementById('addPiiStatus');
  const clr = type === 'error' ? '#ff4d4f' : type === 'ok' ? '#52c41a' : '#1677ff';
  el.style.color   = clr;
  el.textContent   = msg;
}

// ═══════════════════════════════════════════════════════════════════
// UTILITIES
// ═══════════════════════════════════════════════════════════════════
function overlayClose(e, id) {
  if (e.target.id === id) document.getElementById(id).style.display = 'none';
}

function detectDir(text) {
  if (!text) return 'ltr';
  const heb = (text.match(/[֐-׿]/g) || []).length;
  return heb / text.length > 0.12 ? 'rtl' : 'ltr';
}

function h(s)   { return String(s??'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function ha(s)  { return String(s??'').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;'); }
function ea(s)  { return String(s??'').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function escHtml(s) { return String(s??'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function fmtSize(b) {
  if (b < 1024)    return b + ' B';
  if (b < 1048576) return (b/1024).toFixed(1) + ' KB';
  return (b/1048576).toFixed(2) + ' MB';
}
function getToken() {
  const el = document.querySelector('#__AntiForgery input[name="__RequestVerificationToken"]');
  return el ? el.value : '';
}
async function apiPost(url, body) {
  try {
    const r = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
      body: JSON.stringify(body)
    });
    return await r.json();
  } catch (e) { return { ok: false, error: e.message }; }
}
</script>
