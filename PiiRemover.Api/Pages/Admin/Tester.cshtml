<!-- Hidden anti-forgery form -->
<form id="__AntiForgery" style="display:none">@Html.AntiForgeryToken()</form>

<script>
'use strict';

// ═══════════════════════════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════════════════════════
let selectedFiles = [];
const MAX_FILES   = 3;
let previewZoom   = 1;   // 1 = 100%

// Text input state
let textDir      = 'ltr';
let textFontSize = 13;

// Per-card state: { fontSize, dir, ocrText, piiMatches, searchTerm, hitIdx, hitCount }
const cardStates  = new Map();

// Context menu state
let ctxText   = '';
let ctxSource = '';

// Add-PII modal state
let addPiiCurrentText = '';
let cachedFields      = null;    // fetched once per session

// ═══════════════════════════════════════════════════════════════════
// HELP PANEL
// ═══════════════════════════════════════════════════════════════════
function toggleHelp() {
  const panel = document.getElementById('helpPanel');
  const btn   = document.getElementById('helpToggleBtn');
  const open  = panel.style.display === 'none';
  panel.style.display = open ? '' : 'none';
  btn.textContent = open ? '✕ Close guide' : '❓ How to use';
  try { localStorage.setItem('tester-help-open', open ? '1' : '0'); } catch {}
}
// Restore last state
(function() {
  try {
    if (localStorage.getItem('tester-help-open') === '1') {
      document.getElementById('helpPanel').style.display = '';
      document.getElementById('helpToggleBtn').textContent = '✕ Close guide';
    }
  } catch {}
})();

// ═══════════════════════════════════════════════════════════════════
// FILE HANDLING
// ═══════════════════════════════════════════════════════════════════
const dropZone  = document.getElementById('dropZone');
const fileInput = document.getElementById('fileInput');
const runBtn    = document.getElementById('runBtn');

fileInput.addEventListener('change', () => addFiles(fileInput.files));
fileInput.addEventListener('click',  e  => e.stopPropagation());
dropZone.addEventListener('click',   ()  => fileInput.click());
dropZone.addEventListener('dragover',  e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
dropZone.addEventListener('drop',      e => { e.preventDefault(); dropZone.classList.remove('drag-over'); addFiles(e.dataTransfer.files); });

function addFiles(list) {
  for (const f of list) {
    if (selectedFiles.length >= MAX_FILES) break;
    if (!selectedFiles.find(x => x.name === f.name && x.size === f.size))
      selectedFiles.push(f);
  }
  renderChips();
  updatePreview();
  runBtn.disabled = !selectedFiles.length;
  fileInput.value = '';
}

function removeFile(idx) {
  selectedFiles.splice(idx, 1);
  renderChips();
  updatePreview();
  runBtn.disabled = !selectedFiles.length;
}

function renderChips() {
  const chipsHtml = selectedFiles.map((f, i) => {
    const ext  = f.name.split('.').pop().toUpperCase();
    const size = fmtSize(f.size);
    return `<span class="chip">
      <span class="chip-ext">${h(ext)}</span>
      ${h(f.name)} <span style="color:var(--text3)">(${size})</span>
      <button class="chip-remove" onclick="removeFile(${i})">✕</button>
    </span>`;
  }).join('');
  document.getElementById('fileChips').innerHTML     = chipsHtml;
  document.getElementById('fileChipsMini').innerHTML = chipsHtml;
}

function updatePreview() {
  const el      = document.getElementById('filePreview');
  const content = document.getElementById('previewContent');
  if (selectedFiles.length !== 1) { el.style.display = 'none'; return; }
  const f   = selectedFiles[0];
  const ext = f.name.split('.').pop().toLowerCase();
  previewZoom = 1;
  document.getElementById('previewZoomLabel').textContent = '100%';

  if (['png','jpg','jpeg','bmp','tif','tiff','gif','webp'].includes(ext)) {
    const url = URL.createObjectURL(f);
    content.innerHTML = `<img src="${url}" alt="${h(f.name)}" style="max-height:${180*previewZoom}px">`;
    el.style.display = 'block';
  } else if (ext === 'txt') {
    const rd = new FileReader();
    rd.onload = ev => {
      content.innerHTML = `<pre id="previewText" style="font-size:${11*previewZoom}px;max-height:150px;overflow:auto;text-align:left;color:var(--text2);white-space:pre-wrap">${h(String(ev.target.result).slice(0, 800))}</pre>`;
    };
    rd.readAsText(f);
    el.style.display = 'block';
  } else {
    content.innerHTML = `<div style="font-size:13px;color:var(--text2);padding:8px 0">📄 <strong>${h(f.name)}</strong> — ${fmtSize(f.size)}</div>`;
    el.style.display = 'block';
  }
}

function zoomPreview(delta) {
  if (delta === 0) previewZoom = 1; // reset
  else previewZoom = Math.max(0.25, Math.min(5, previewZoom + delta));
  document.getElementById('previewZoomLabel').textContent = Math.round(previewZoom * 100) + '%';
  const img  = document.querySelector('#previewContent img');
  const pre  = document.getElementById('previewText');
  if (img) img.style.maxHeight = (180 * previewZoom) + 'px';
  if (pre) pre.style.fontSize  = (11 * previewZoom) + 'px';
}

// ═══════════════════════════════════════════════════════════════════
// TABS
// ═══════════════════════════════════════════════════════════════════
let currentTab = 'file';

function switchTab(tab) {
  currentTab = tab;
  document.querySelectorAll('.tab-btn').forEach(b =>
    b.classList.toggle('active', b.dataset.tab === tab));
  document.querySelectorAll('.tab-panel').forEach(p =>
    p.classList.toggle('active', p.dataset.tab === tab));

  // toggle mode rows and run buttons
  const isFile = tab === 'file';
  document.getElementById('fileModeRow').style.display    = isFile ? '' : 'none';
  document.getElementById('textModeRow').style.display    = isFile ? 'none' : '';
  document.getElementById('runBtn').style.display         = isFile ? '' : 'none';
  document.getElementById('analyzeTextBtn').style.display = isFile ? 'none' : '';
  document.getElementById('runStatus').style.display      = isFile ? '' : 'none';
  document.getElementById('textRunStatus').style.display  = isFile ? 'none' : '';
}

// ═══════════════════════════════════════════════════════════════════
// TEXT INPUT HANDLERS
// ═══════════════════════════════════════════════════════════════════
function onTextInput() {
  const ta  = document.getElementById('textInput');
  const val = ta ? ta.value : '';
  document.getElementById('analyzeTextBtn').disabled = !val.trim();
  document.getElementById('textClearBtn').style.display = val.length ? '' : 'none';
  document.getElementById('textCharCount').textContent = val.length.toLocaleString() + ' chars';
}

function clearTextInput() {
  const ta = document.getElementById('textInput');
  if (ta) ta.value = '';
  onTextInput();
}

function textToggleDir() {
  textDir = textDir === 'rtl' ? 'ltr' : 'rtl';
  const btn = document.getElementById('textDirBtn');
  if (btn) btn.textContent = textDir === 'rtl' ? '→ LTR' : '← RTL';
  const ta = document.getElementById('textInput');
  if (ta) ta.dir = textDir;
}

function textChangeFontSize(delta) {
  textFontSize = Math.max(9, Math.min(20, textFontSize + delta));
  const lbl = document.getElementById('textFszLabel');
  if (lbl) lbl.textContent = textFontSize + 'px';
  const ta = document.getElementById('textInput');
  if (ta) ta.style.fontSize = textFontSize + 'px';
}

async function runTextAnalysis() {
  const ta = document.getElementById('textInput');
  const text = ta ? ta.value.trim() : '';
  if (!text) return;

  const redactOnly = document.querySelector('input[name="textMode"]:checked')?.value === 'redact-only';

  const btn      = document.getElementById('analyzeTextBtn');
  const statusEl = document.getElementById('textRunStatus');
  btn.disabled = true;
  document.getElementById('textRunIcon').textContent = '⏳';
  statusEl.textContent = 'Analyzing…';

  const id        = 'rc-text-' + Date.now();
  const container = document.getElementById('results');
  container.insertAdjacentHTML('beforeend', buildSkeletonCardText(id, text.length));

  const token = getToken();
  try {
    const r = await fetch('/admin/tester?handler=RedactText', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
      body: JSON.stringify({ text })
    });
    const data = await r.json();
    if (!r.ok) throw new Error(data.error || `HTTP ${r.status}`);
    renderResultText(id, text, data, redactOnly);
    statusEl.textContent = '';
    document.getElementById('clearBtn').style.display     = '';
    document.getElementById('clearBtnMini').style.display = '';
  } catch (err) {
    renderError(id, { name: 'Text Input', size: 0 }, String(err));
    statusEl.textContent = '⚠ ' + err.message;
  } finally {
    document.getElementById('textRunIcon').textContent = '▶';
    btn.disabled = !(document.getElementById('textInput')?.value.trim());
  }
}

// ═══════════════════════════════════════════════════════════════════
// RUN FILE ANALYSIS
// ═══════════════════════════════════════════════════════════════════
function collapseUpload() {
  document.getElementById('uploadCard').classList.add('upload-collapsed');
}
function expandUpload() {
  document.getElementById('uploadCard').classList.remove('upload-collapsed');
}

async function runFileAnalysis() {
  if (!selectedFiles.length) return;
  const ocrOnly = document.querySelector('input[name="fileMode"]:checked')?.value === 'ocr-only';
  collapseUpload();
  runBtn.disabled = true;
  document.getElementById('runBtnMini').disabled = true;
  runBtn.querySelector('#runIcon').textContent  = '⏳';
  runBtn.querySelector('#runLabel').textContent = 'Processing…';
  const statusEl     = document.getElementById('runStatus');
  const statusElMini = document.getElementById('runStatusMini');
  statusEl.textContent = statusElMini.textContent = `Sending ${selectedFiles.length} file(s)…`;

  const container = document.getElementById('results');
  container.innerHTML = '';
  const ids = selectedFiles.map((f, i) => {
    const id = 'rc-' + Date.now() + '-' + i;
    container.insertAdjacentHTML('beforeend', buildSkeletonCard(f, id));
    return id;
  });

  const token = getToken();
  let done = 0;
  await Promise.all(selectedFiles.map((file, i) =>
    uploadAnalyze(file, token, ocrOnly)
      .then(data => { done++; const msg = `${done}/${selectedFiles.length} done…`; statusEl.textContent = statusElMini.textContent = msg; renderResult(ids[i], file, data, ocrOnly); })
      .catch(err  => { done++; const msg = `${done}/${selectedFiles.length} done…`; statusEl.textContent = statusElMini.textContent = msg; renderError(ids[i], file, String(err)); })
  ));

  statusEl.textContent = statusElMini.textContent = '';
  runBtn.querySelector('#runIcon').textContent  = '▶';
  runBtn.querySelector('#runLabel').textContent = 'Analyze File';
  runBtn.disabled = !selectedFiles.length;
  document.getElementById('runBtnMini').disabled = !selectedFiles.length;
  document.getElementById('clearBtn').style.display     = '';
  document.getElementById('clearBtnMini').style.display = '';
}

// backward compat alias (mini bar uses runAnalysis in some paths)
function runAnalysis() { runFileAnalysis(); }

async function uploadAnalyze(file, token, ocrOnly) {
  const fd      = new FormData();
  const handler = ocrOnly ? 'OcrOnly' : 'Analyze';
  fd.append('file', file);
  const r = await fetch(`/admin/tester?handler=${handler}`, {
    method: 'POST', headers: { 'RequestVerificationToken': token }, body: fd
  });
  const body = await r.json();
  if (!r.ok) throw new Error(body.error || body.detail || `HTTP ${r.status}`);
  return body;
}

function clearResults() {
  document.getElementById('results').innerHTML = '';
