      <span>▶</span> Re-run File
    </button>
    <button class="btn btn-default btn-sm" id="clearBtnMini" style="display:none" onclick="clearResults()">✕ Clear</button>
    <span class="run-status" id="runStatusMini" style="font-size:11px"></span>
  </div>

  <!-- ─ Tab bar ─ -->
  <div class="tab-bar upload-title">
    <button class="tab-btn active" data-tab="file" onclick="switchTab('file')">📂 File</button>
