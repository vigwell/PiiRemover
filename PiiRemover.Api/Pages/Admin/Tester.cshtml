@page "/admin/tester"
@model PiiRemover.Api.Pages.Admin.TesterModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Live Tester";
    ViewData["Nav"] = "tester";
}

<style>
.page { max-width:100% !important; padding:0 20px !important; }

/* ── Drop zone ─────────────────────────────────────────────────── */
.drop-zone {
  border:2px dashed var(--border2); border-radius:10px; padding:28px 24px;
  text-align:center; cursor:pointer; transition:border-color .2s,background .2s;
  background:var(--surface2); position:relative;
}
.drop-zone.drag-over { border-color:#1677ff; background:rgba(22,119,255,.06); }
.drop-zone input[type=file] { position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%; }
.drop-hint { color:var(--text3); font-size:12px; margin-top:4px; }
.file-chips { display:flex;flex-wrap:wrap;gap:8px;margin-top:12px;min-height:28px; }
.chip { display:inline-flex;align-items:center;gap:5px;background:var(--surface);
        border:1px solid var(--border2);border-radius:20px;padding:3px 10px;font-size:12px;color:var(--text2); }
.chip-remove { cursor:pointer;color:var(--text3);font-size:13px;background:none;border:none;
               padding:0;transition:color .15s; }
.chip-remove:hover { color:#ff4d4f; }
.chip-ext { background:rgba(22,119,255,.15);color:#1677ff;border-radius:3px;
            padding:1px 5px;font-size:10px;font-weight:700;text-transform:uppercase; }

/* ── Run bar ───────────────────────────────────────────────────── */
.run-bar { display:flex;align-items:center;gap:10px;margin-top:14px;flex-wrap:wrap; }
.btn-run { background:#1677ff;color:#fff;border:none;padding:8px 24px;border-radius:6px;
           font-size:13px;font-weight:600;cursor:pointer;transition:background .2s;
           display:flex;align-items:center;gap:6px; }
.btn-run:hover:not(:disabled) { background:#0958d9; }
.btn-run:disabled { background:var(--border2);cursor:not-allowed;color:var(--text3); }
.run-status { font-size:12px;color:var(--text3); }

/* ── File preview ──────────────────────────────────────────────── */
.file-preview { margin-top:12px;padding:10px;border:1px solid var(--border);
                border-radius:6px;background:var(--mono-bg);text-align:center;
                overflow:hidden;position:relative; }
.file-preview img { max-width:100%;border-radius:4px;object-fit:contain;
                    display:block;margin:0 auto;
                    transition:max-height .2s; }
.preview-zoom-bar { display:flex;align-items:center;justify-content:center;gap:6px;
                    padding:5px 0 2px;font-size:12px;color:var(--text3); }
.preview-zoom-bar button { background:var(--surface);border:1px solid var(--border2);
  color:var(--text2);padding:1px 8px;border-radius:3px;cursor:pointer;font-size:12px; }
.preview-zoom-bar button:hover { border-color:#1677ff;color:#1677ff; }

/* ── Upload card collapsed ─────────────────────────────────────── */
.upload-collapsed .drop-zone,
.upload-collapsed .file-preview { display:none !important; }
.upload-collapsed { padding:8px 14px !important; }
.upload-collapsed .upload-title { display:none; }
.upload-mini-bar { display:none;align-items:center;gap:8px;flex-wrap:wrap; }
.upload-collapsed .upload-mini-bar { display:flex; }
.upload-expand-btn { background:none;border:1px solid var(--border2);color:var(--text3);
  padding:2px 9px;border-radius:4px;font-size:12px;cursor:pointer;white-space:nowrap; }
.upload-expand-btn:hover { border-color:#1677ff;color:#1677ff; }

/* ── Basket button ─────────────────────────────────────────────── */
.basket-btn {
  display:inline-flex;align-items:center;gap:6px;
  background:var(--surface);border:1px solid var(--border2);
  color:var(--text2);padding:6px 14px;border-radius:6px;font-size:13px;
  cursor:pointer;transition:all .2s;position:relative;
}
.basket-btn:hover { border-color:#faad14;color:#faad14; }
.basket-btn.has-items { border-color:#faad14;color:#faad14; }
.basket-count {
  background:#faad14;color:#000;border-radius:10px;padding:0 6px;
  font-size:11px;font-weight:700;min-width:18px;text-align:center;
}

/* ── Result card ───────────────────────────────────────────────── */
.result-card { background:var(--surface);border:1px solid var(--border);
               border-radius:10px;margin-bottom:20px;overflow:hidden;box-shadow:var(--shadow); }
.result-header { display:flex;align-items:center;gap:10px;padding:10px 16px;
                 border-bottom:1px solid var(--border);background:var(--surface2); }
.result-header .fname { font-weight:600;font-size:14px;flex:1;
                         white-space:nowrap;overflow:hidden;text-overflow:ellipsis; }
.result-header .fsize { color:var(--text3);font-size:12px; }
.status-dot { width:9px;height:9px;border-radius:50%;flex-shrink:0; }
.status-dot.pending { background:var(--text3); }
.status-dot.running { background:#faad14;animation:pulse 1s infinite; }
.status-dot.done    { background:#52c41a; }
.status-dot.error   { background:#ff4d4f; }
@@keyframes pulse { 0%,100%{opacity:1}50%{opacity:.3} }

/* ── Stats bar ─────────────────────────────────────────────────── */
.stats-bar { display:flex;align-items:center;flex-wrap:wrap;gap:0;padding:6px 16px;
             border-bottom:1px solid var(--border);font-size:12px;color:var(--text2); }
.stat-item { display:flex;align-items:center;gap:4px;padding:2px 12px 2px 0;
             margin-right:12px;border-right:1px solid var(--border); }
.stat-item:last-child { border-right:none; }
.stat-val { font-weight:700;color:var(--text); }
.stat-val.blue { color:#1677ff; }
.stat-val.warn { color:#faad14; }
.stat-val.good { color:#52c41a; }
.fields-row { padding:5px 16px;border-bottom:1px solid var(--border);
              font-size:12px;display:flex;align-items:center;flex-wrap:wrap;gap:5px; }
.field-chip { background:rgba(26,111,240,.12);color:#4a90d9;
              border:1px solid rgba(26,111,240,.2);border-radius:4px;
              padding:1px 7px;font-size:11px;font-weight:600; }

/* ── Card toolbar ──────────────────────────────────────────────── */
.card-toolbar {
  display:flex;align-items:center;gap:6px;padding:7px 14px;
  border-bottom:1px solid var(--border);background:var(--surface2);flex-wrap:wrap;
}
.tb-btn {
  background:var(--surface);border:1px solid var(--border2);color:var(--text2);
  padding:3px 9px;border-radius:4px;font-size:12px;cursor:pointer;
  transition:all .15s;white-space:nowrap;
}
.tb-btn:hover { border-color:#1677ff;color:#1677ff; }
.tb-btn.active { background:rgba(22,119,255,.12);border-color:#1677ff;color:#1677ff; }
.tb-sep { width:1px;height:20px;background:var(--border2);flex-shrink:0; }
.tb-font-size { font-size:11px;font-weight:600;color:var(--text3);min-width:30px;text-align:center; }
.search-wrap { display:flex;align-items:center;gap:4px;flex:1;min-width:140px;max-width:300px; }
.search-wrap input {
  flex:1;background:var(--surface);color:var(--text);border:1px solid var(--border2);
  border-radius:4px;padding:3px 8px;font-size:12px;outline:none;
}
.search-wrap input:focus { border-color:#1677ff; }
.search-badge { font-size:11px;color:var(--text3);white-space:nowrap;min-width:40px; }
.tb-btn.nav-btn { padding:3px 7px; }

/* ── Split pane ────────────────────────────────────────────────── */
.split-pane { display:grid;grid-template-columns:1fr 1fr;
              height:calc(50vh - 10px);min-height:260px; }
.pane { display:flex;flex-direction:column;overflow:hidden;border-right:1px solid var(--border); }
.pane:last-child { border-right:none; }
.pane-header { padding:7px 12px;font-size:12px;font-weight:600;letter-spacing:.3px;
               border-bottom:1px solid var(--border);flex-shrink:0;
               display:flex;align-items:center;gap:6px; }
.pane-ocr    .pane-header { background:rgba(22,119,255,.07);color:#4a90d9; }
.pane-redact .pane-header { background:rgba(82,196,26,.07); color:#52c41a; }
.pane-time { margin-left:auto;font-weight:400;color:var(--text3);font-size:11px; }
.pane-body {
  flex:1;overflow-y:auto;overflow-x:auto;padding:10px 12px;
  font-family:'Cascadia Code','Consolas','Courier New',monospace;
  line-height:1.75;white-space:pre-wrap;word-break:break-word;
  color:var(--text2);background:var(--mono-bg);
}
.pane-body::-webkit-scrollbar { width:5px;height:5px; }
.pane-body::-webkit-scrollbar-thumb { background:var(--border2);border-radius:3px; }

/* ── Highlights ────────────────────────────────────────────────── */
mark.pii-orig {
  background:rgba(250,173,20,.22);border-bottom:2px solid #faad14;
  border-radius:2px;color:inherit;cursor:help;padding:0 1px;
}
mark.pii-repl {
  background:rgba(82,196,26,.2);border-bottom:2px solid #52c41a;
  border-radius:2px;color:#52c41a;font-weight:700;cursor:help;padding:0 1px;
}
mark.search-hit {
  background:rgba(22,119,255,.25);border-bottom:2px solid #1677ff;
  border-radius:2px;color:inherit;padding:0 1px;
}
mark.search-hit.active {
  background:rgba(255,165,0,.45);border-color:#fa8c16;
}

/* ── Legend ────────────────────────────────────────────────────── */
.legend { display:flex;gap:14px;align-items:center;padding:5px 16px;
          border-top:1px solid var(--border);font-size:11px;color:var(--text3); }
.legend-swatch { display:inline-block;width:24px;height:10px;border-radius:2px;flex-shrink:0; }

/* ── Skeleton ──────────────────────────────────────────────────── */
.skeleton-line { height:11px;border-radius:3px;margin:7px 0;
  background:linear-gradient(90deg,var(--border) 25%,var(--surface2) 50%,var(--border) 75%);
  background-size:200% 100%;animation:shimmer 1.4s infinite; }
@@keyframes shimmer { 0%{background-position:200% 0}100%{background-position:-200% 0} }
.pane-error { color:#ff4d4f;font-size:12px;padding:16px 14px;background:var(--mono-bg);flex:1; }

/* ── Context menu ──────────────────────────────────────────────── */
.ctx-menu {
  position:fixed;z-index:9000;background:var(--surface);border:1px solid var(--border2);
  border-radius:6px;box-shadow:0 4px 16px rgba(0,0,0,.35);min-width:190px;overflow:hidden;
}
.ctx-item {
  padding:8px 14px;font-size:13px;cursor:pointer;color:var(--text);
  transition:background .1s;display:flex;align-items:center;gap:8px;
}
.ctx-item:hover { background:rgba(22,119,255,.1);color:#1677ff; }

/* ── Modals ────────────────────────────────────────────────────── */
.modal-overlay {
  position:fixed;inset:0;z-index:8000;background:rgba(0,0,0,.6);
  display:flex;align-items:center;justify-content:center;padding:20px;
}
.modal-box {
  background:var(--surface);border:1px solid var(--border2);border-radius:10px;
  width:100%;max-width:480px;box-shadow:0 8px 40px rgba(0,0,0,.5);
  display:flex;flex-direction:column;max-height:90vh;
}
.modal-box.modal-wide { max-width:640px; }
.modal-header {
  padding:14px 18px;border-bottom:1px solid var(--border);font-weight:600;font-size:15px;
  display:flex;align-items:center;justify-content:space-between;flex-shrink:0;
}
.modal-close { background:none;border:none;color:var(--text3);font-size:18px;
               cursor:pointer;padding:0;line-height:1; }
.modal-close:hover { color:#ff4d4f; }
.modal-body { padding:16px 18px;overflow-y:auto;flex:1; }
.modal-footer { padding:10px 18px;border-top:1px solid var(--border);
                display:flex;justify-content:flex-end;gap:8px;flex-shrink:0; }

/* ── Basket items ──────────────────────────────────────────────── */
.basket-item {
  display:flex;align-items:flex-start;gap:10px;padding:10px 0;
  border-bottom:1px solid var(--border);
}
.basket-item:last-child { border-bottom:none; }
.basket-text { font-family:'Consolas','Courier New',monospace;font-size:13px;
               color:var(--text);background:var(--mono-bg);border:1px solid var(--border);
               border-radius:4px;padding:3px 8px;flex:1;word-break:break-all; }
.basket-source { font-size:11px;color:var(--text3);margin-top:3px; }
.basket-actions { display:flex;gap:5px;flex-shrink:0;margin-top:2px; }

/* ── Add PII form ──────────────────────────────────────────────── */
.pii-mode-radio { display:flex;flex-direction:column;gap:12px;margin-bottom:14px; }
.pii-mode-option { display:flex;align-items:flex-start;gap:8px;cursor:pointer; }
.pii-mode-option input { margin-top:3px;flex-shrink:0; }
.pii-mode-label { font-weight:600;font-size:13px; }
.pii-mode-body { display:none;margin-top:8px;padding:10px;background:var(--surface2);
                 border:1px solid var(--border);border-radius:6px; }
.pii-mode-body.active { display:block; }
.form-label { font-size:12px;font-weight:600;color:var(--text2);margin-bottom:4px;display:block; }
.form-ctrl { background:var(--surface);color:var(--text);border:1px solid var(--border2);
             border-radius:4px;padding:6px 9px;font-size:13px;width:100%;
             outline:none;margin-bottom:8px; }
.form-ctrl:focus { border-color:#1677ff; }
.pattern-pill { display:inline-block;font-family:'Consolas','Courier New',monospace;
                font-size:12px;background:rgba(250,173,20,.15);border:1px solid #faad14;
                border-radius:4px;padding:2px 8px;color:#faad14;margin-bottom:12px; }

/* ── Tabs ──────────────────────────────────────────────────────── */
.tab-bar {
  display:flex;border-bottom:2px solid var(--border);
  margin:-4px -4px 16px;       /* bleed to card edges */
}
.tab-btn {
  padding:9px 20px;font-size:13px;font-weight:600;cursor:pointer;
  border:none;background:none;color:var(--text3);
  border-bottom:2px solid transparent;margin-bottom:-2px;
  transition:color .15s,border-color .15s;white-space:nowrap;
}
.tab-btn:hover:not(.active) { color:var(--text); }
.tab-btn.active { color:#1677ff;border-bottom-color:#1677ff; }
.tab-panel { display:none; }
.tab-panel.active { display:block; }

/* ── Mode radio row ────────────────────────────────────────────── */
.mode-row { display:flex;align-items:center;gap:16px;flex-wrap:wrap; }
.mode-row label {
  display:flex;align-items:center;gap:5px;font-size:12px;cursor:pointer;color:var(--text2);
  padding:4px 10px;border:1px solid var(--border2);border-radius:5px;transition:all .15s;
}
.mode-row label:hover { border-color:#1677ff;color:#1677ff; }
.mode-row input[type=radio]:checked + span { color:var(--text);font-weight:600; }
.mode-row label:has(input:checked) { border-color:#1677ff;background:rgba(22,119,255,.07);color:#1677ff; }

/* ── Run area (shared bottom) ──────────────────────────────────── */
.run-area {
  margin-top:14px;padding-top:12px;border-top:1px solid var(--border);
  display:flex;align-items:center;gap:14px;flex-wrap:wrap;
}

/* ── Text textarea ─────────────────────────────────────────────── */
.text-toolbar { display:flex;align-items:center;gap:6px;margin-bottom:8px;flex-wrap:wrap; }
.text-input-area {
  width:100%;min-height:110px;max-height:340px;resize:vertical;
  background:var(--mono-bg);color:var(--text);border:1px solid var(--border2);
  border-radius:6px;padding:10px 12px;font-size:13px;line-height:1.75;
  font-family:'Cascadia Code','Consolas','Courier New',monospace;
  outline:none;box-sizing:border-box;transition:border-color .15s;
}
.text-input-area:focus { border-color:#1677ff; }
.text-input-area::placeholder { color:var(--text3);font-style:italic; }

/* ── Single-pane (OCR-only / Redact-only) ─────────────────────── */
.split-pane.pane-single { grid-template-columns:1fr !important; }
.pane-single .pane:first-child { border-right:none; }

/* Help panel ────────────────────────────────────────────────── */
.help-toggle {
  display:inline-flex;align-items:center;gap:5px;
  background:none;border:1px solid var(--border2);color:var(--text3);
  padding:4px 12px;border-radius:4px;font-size:12px;cursor:pointer;
  transition:all .15s;
}
.help-toggle:hover { border-color:#1677ff;color:#1677ff; }
.help-panel {
  background:var(--surface);border:1px solid var(--border);border-radius:10px;
  margin-bottom:16px;overflow:hidden;box-shadow:var(--shadow);
}
.help-sections { display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));gap:0; }
.help-section {
  padding:14px 18px;border-bottom:1px solid var(--border);border-right:1px solid var(--border);
}
.help-section:last-child { border-bottom:none; }
.help-section-title {
  font-size:12px;font-weight:700;letter-spacing:.4px;text-transform:uppercase;
  color:var(--text3);margin-bottom:10px;display:flex;align-items:center;gap:6px;
}
.help-row { display:flex;align-items:flex-start;gap:8px;margin-bottom:8px;font-size:12px; }
.help-row:last-child { margin-bottom:0; }
.help-icon { font-size:14px;flex-shrink:0;width:20px;text-align:center; }
.help-text { color:var(--text2);line-height:1.55; }
.help-text strong { color:var(--text); }
.help-key {
  display:inline-block;background:var(--surface2);border:1px solid var(--border2);
  border-radius:3px;padding:0 5px;font-size:11px;font-family:'Consolas',monospace;
  color:var(--text2);vertical-align:middle;
}
.help-swatch {
  display:inline-block;width:28px;height:9px;border-radius:2px;
  vertical-align:middle;flex-shrink:0;margin-top:3px;
}
</style>

<!-- ── Page header ──────────────────────────────────────────────────────── -->
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
  <h1 class="page-title" style="margin:0">🔍 Live Tester &amp; Demo</h1>
  <div style="display:flex;align-items:center;gap:10px">
    <button class="help-toggle" id="helpToggleBtn" onclick="toggleHelp()">❓ How to use</button>
    <button class="basket-btn" id="basketBtn" onclick="openBasket()">
      🧺 <span class="basket-count" id="basketCount">0</span>&nbsp;Missing Patterns
    </button>
  </div>
</div>

<!-- ── Help panel ─────────────────────────────────────────────────────────── -->
<div class="help-panel" id="helpPanel" style="display:none">
  <div style="display:flex;align-items:center;justify-content:space-between;
              padding:10px 18px;border-bottom:1px solid var(--border);background:var(--surface2)">
    <span style="font-size:13px;font-weight:600;color:var(--text)">📖 Live Tester — Feature Guide</span>
    <button class="help-toggle" onclick="toggleHelp()" style="padding:2px 9px">✕ Close</button>
  </div>
  <div class="help-sections">

    <!-- Upload -->
    <div class="help-section">
      <div class="help-section-title">📂 File Analysis</div>
      <div class="help-row">
        <span class="help-icon">📄</span>
        <span class="help-text"><strong>Drag &amp; drop</strong> or <strong>click</strong> the drop zone to browse. Up to <strong>3 files</strong> at once: PDF, PNG, JPG, TIFF, BMP, TXT.</span>
      </div>
      <div class="help-row">
        <span class="help-icon">⚙</span>
        <span class="help-text">Choose mode: <strong>OCR + Redact</strong> (default) runs OCR then redaction and shows two panes. <strong>OCR only</strong> just extracts text — single pane, no PII detection.</span>
      </div>
      <div class="help-row">
        <span class="help-icon">▶</span>
        <span class="help-text">Click <strong>Analyze File</strong> to send all files — OCR and Redaction run in parallel for each.</span>
      </div>
      <div class="help-row">
        <span class="help-icon">⊕</span>
        <span class="help-text">After running the upload area <strong>collapses</strong>. Click <strong>⊕ Change files</strong> in the mini bar to swap, then <strong>Re-run File</strong> to re-analyze.</span>
      </div>
    </div>

    <!-- Text input -->
    <div class="help-section">
      <div class="help-section-title">📝 Text Input</div>
      <div class="help-row">
        <span class="help-icon">✍</span>
        <span class="help-text">Use the <strong>📝 Type or Paste Text</strong> card to redact text directly — no file upload needed. Works for both English and Hebrew.</span>
      </div>
      <div class="help-row">
        <span class="help-icon">⇄</span>
        <span class="help-text">The <strong>← RTL / → LTR</strong> and <strong>A− / A+</strong> buttons in the text toolbar control direction and font size of the textarea independently from result cards.</span>
      </div>
      <div class="help-row">
        <span class="help-icon">▶</span>
        <span class="help-text"><strong>Analyze Text</strong> is enabled as soon as you type something. Click it to run redaction — results appear as a card below (same two-pane view as file analysis).</span>
      </div>
      <div class="help-row">
        <span class="help-icon">💡</span>
        <span class="help-text">You can run <em>both</em> file analysis and text analysis independently. Results stack up — use <strong>✕ Clear Results</strong> to reset.</span>
      </div>
    </div>

    <!-- Results layout -->
    <div class="help-section">
      <div class="help-section-title">📊 Results Card</div>
      <div class="help-row">
        <span class="help-icon">⏱</span>
        <span class="help-text">Each card shows <strong>OCR duration</strong>, <strong>Redact duration</strong>, number of <strong>PII hits</strong>, character count, and the OCR engine used.</span>
      </div>
      <div class="help-row">
        <span class="help-icon">🏷</span>
        <span class="help-text">The <strong>FIELDS</strong> row lists every PII field that matched (e.g. "Israeli ID", "Email Address"). Empty = no PII found.</span>
      </div>
      <div class="help-row">
        <span class="help-icon">📄</span>
        <span class="help-text"><strong>Left pane (OCR)</strong> — raw extracted text with detected PII highlighted in
          <span class="help-swatch" style="background:rgba(250,173,20,.35);border-bottom:2px solid #faad14"></span> amber.
        </span>
      </div>
      <div class="help-row">
        <span class="help-icon">🔒</span>
        <span class="help-text"><strong>Right pane (Redacted)</strong> — same text with PII replaced, shown in
          <span class="help-swatch" style="background:rgba(82,196,26,.25);border-bottom:2px solid #52c41a"></span> green.
          Hover any highlight for details.
        </span>
      </div>
      <div class="help-row">
        <span class="help-icon">↕</span>
        <span class="help-text">Both panes <strong>scroll together</strong> — scrolling either pane proportionally moves the other so OCR and Redacted stay aligned.</span>
      </div>
    </div>

    <!-- Toolbar -->
    <div class="help-section">
      <div class="help-section-title">🛠 Card Toolbar</div>
      <div class="help-row">
        <span class="help-icon">⇄</span>
        <span class="help-text"><strong>← RTL / → LTR</strong> button toggles text direction for <em>both</em> panes simultaneously. Detected automatically from Hebrew character ratio; override manually if needed.</span>
      </div>
      <div class="help-row">
        <span class="help-icon">Aa</span>
        <span class="help-text"><strong>A− / A+</strong> decrease or increase font size (9–20 px) for both panes at once, so columns stay comparable.</span>
      </div>
      <div class="help-row">
        <span class="help-icon">🔍</span>
        <span class="help-text"><strong>Search box</strong> — type to highlight matches in
          <span class="help-swatch" style="background:rgba(22,119,255,.3);border-bottom:2px solid #1677ff"></span> blue
          across both panes. The badge shows <em>current / total</em> hits.</span>
      </div>
      <div class="help-row">
        <span class="help-icon">↑↓</span>
        <span class="help-text">Use <span class="help-key">↑</span> <span class="help-key">↓</span> buttons (or <span class="help-key">Enter</span> / <span class="help-key">Shift+Enter</span>) to jump between hits. Both panes scroll to the same position.</span>
      </div>
      <div class="help-row">
        <span class="help-icon">✕</span>
        <span class="help-text"><span class="help-key">✕</span> or <span class="help-key">Esc</span> clears the search and removes highlights.</span>
      </div>
    </div>

    <!-- Right-click & basket -->
    <div class="help-section">
      <div class="help-section-title">🧺 Missing Patterns &amp; Right-Click</div>
      <div class="help-row">
        <span class="help-icon">🖱</span>
        <span class="help-text"><strong>Select any text</strong> in the <em>Redacted</em> pane and <strong>right-click</strong> to see the context menu.</span>
      </div>
      <div class="help-row">
        <span class="help-icon">🧺</span>
        <span class="help-text"><strong>Collect Missing Pattern</strong> — saves the selection to the <strong>basket</strong> at the top of the page. Review later and decide what to do with each one.</span>
      </div>
      <div class="help-row">
        <span class="help-icon">➕</span>
        <span class="help-text"><strong>Add to PII Field</strong> — opens the <em>Add to PII Fields &amp; Patterns</em> dialog immediately, skipping the basket.</span>
      </div>
      <div class="help-row">
        <span class="help-icon">📌</span>
        <span class="help-text">The basket persists for the <strong>whole browser session</strong>. Click <strong>🧺 Missing Patterns</strong> to review, remove items, or push each one directly to a PII field.</span>
      </div>
    </div>

    <!-- Add to PII Field modal -->
    <div class="help-section">
      <div class="help-section-title">➕ Add to PII Fields &amp; Patterns</div>
      <div class="help-row">
        <span class="help-icon">1️⃣</span>
        <span class="help-text"><strong>Add to existing field</strong> — pick a field, then either <em>append to a const-list pattern</em> (adds a new keyword) or <em>add a new pattern</em> of any type to that field.</span>
      </div>
      <div class="help-row">
        <span class="help-icon">2️⃣</span>
        <span class="help-text"><strong>Create new field</strong> — give the field a name, replacement text (e.g. <code style="font-size:11px">[NAME]</code>), choose a pattern type and enter the pattern. The new field is active immediately.</span>
      </div>
      <div class="help-row">
        <span class="help-icon">🔄</span>
        <span class="help-text">Changes take effect on the <strong>next Run Analysis</strong> — the PII fields cache is invalidated automatically so the redaction engine picks up the new rule.</span>
      </div>
      <div class="help-row">
        <span class="help-icon">📖</span>
        <span class="help-text">Not sure which pattern type to use? See <a href="/admin/pattern-help" target="_blank" style="color:#1677ff">📖 Pattern Help</a> for examples of all 11 types.</span>
      </div>
    </div>

    <!-- Tips -->
    <div class="help-section" style="border-right:none">
      <div class="help-section-title">💡 Tips &amp; Tricks</div>
