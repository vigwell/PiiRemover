      <span><span class="legend-swatch" style="background:rgba(250,173,20,.35);border-bottom:2px solid #faad14;vertical-align:middle"></span> PII found</span>
      <span><span class="legend-swatch" style="background:rgba(82,196,26,.25);border-bottom:2px solid #52c41a;vertical-align:middle"></span> Redacted</span>
      <span><span class="legend-swatch" style="background:rgba(22,119,255,.3);border-bottom:2px solid #1677ff;vertical-align:middle"></span> Search hit</span>
