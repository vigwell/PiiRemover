@page "/admin"
@model PiiRemover.Api.Pages.Admin.IndexModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard";
    ViewData["Nav"] = "home";
}

<h1 class="page-title">Dashboard</h1>

@if (Model.DaysUntilExpiry <= 30)
{
    <div class="alert alert-warning">
        ⚠️ License expires in <strong>@Model.DaysUntilExpiry day(s)</strong>
        (@Model.LicenseExpiry.ToString("yyyy-MM-dd")). Contact your vendor to renew.
    </div>
}

<div class="grid-3">
    <div class="card"><div class="stat">
        <div class="val">@Model.TotalClients</div>
        <div class="lbl">Active Clients</div>
    </div></div>
    <div class="card"><div class="stat">
        <div class="val">@Model.TotalFields</div>
        <div class="lbl">PII Fields</div>
    </div></div>
    <div class="card"><div class="stat">
        <div class="val">@Model.TotalLogs</div>
        <div class="lbl">Total Requests</div>
    </div></div>
</div>

<div class="grid-2">
    <div class="card">
        <h3>License</h3>
        <table>
            <tr><td>Organisation</td><td><strong>@Model.License.OrgName</strong></td></tr>
            <tr><td>License ID</td><td><span class="mono">@Model.License.LicenseId</span></td></tr>
            <tr><td>Issued</td><td>@Model.License.IssuedDate.ToString("yyyy-MM-dd")</td></tr>
            <tr><td>Expires</td><td>
                @if (Model.DaysUntilExpiry <= 7)
                {
                    <span class="badge badge-red">@Model.License.ExpiryDate.ToString("yyyy-MM-dd") (@Model.DaysUntilExpiry d)</span>
                }
                else if (Model.DaysUntilExpiry <= 30)
                {
                    <span class="badge badge-blue">@Model.License.ExpiryDate.ToString("yyyy-MM-dd") (@Model.DaysUntilExpiry d)</span>
                }
                else
                {
                    <span class="badge badge-green">@Model.License.ExpiryDate.ToString("yyyy-MM-dd")</span>
                }
            </td></tr>
            <tr><td>Request Quota</td><td>
                @if (Model.License.RequestQuota == 0)
                {
                    <span class="badge badge-green">Unlimited</span>
                }
                else
                {
                    <text>@Model.QuotaUsed.ToString("N0") / @Model.License.RequestQuota.ToString("N0")</text>
                }
            </td></tr>
            <tr><td>Features</td><td>@string.Join(", ", Model.License.Features)</td></tr>
        </table>
    </div>

    <div class="card">
        <h3>Quick Links</h3>
        <ul style="line-height:2.2;padding-left:4px;list-style:none">
            <li>→ <a href="/admin/clients">Manage Clients & API Keys</a></li>
            <li>→ <a href="/admin/fields">Configure PII Fields & Patterns</a></li>
            <li>→ <a href="/admin/logs">View Request Logs</a></li>
            <li>→ <a href="/admin/settings">System Settings</a></li>
        </ul>
    </div>
</div>
